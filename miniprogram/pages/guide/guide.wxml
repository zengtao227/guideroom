<view class="container">
  <view class="card qr-card">
    <text class="label">让访客用微信扫此二维码收听</text>
    <image class="qrcode" src="{{qrcodeUrl}}" mode="aspectFit" />
    <text class="room-id" bindtap="copyRoomId">{{listenerToken}}</text>
    <text class="hint">点击房间码可复制</text>
  </view>

  <view class="card row">
    <text class="label">当前收听人数</text>
    <text class="count">{{listenerCount}}</text>
  </view>

  <button class="btn-mic {{micOn ? 'active' : ''}}" bindtap="toggleMic">
    {{micOn ? '🎙 停止讲话' : '🎙 开始讲话'}}
  </button>

  <button class="btn-end" bindtap="endRoom">结束房间</button>
</view>
