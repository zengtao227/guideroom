<view class="container">
  <view class="hero">
    <text class="tagline">GuideRoom</text>
    <text class="headline">Create a live audio room</text>
    <text class="desc">Visitors scan and listen with their own phones.</text>
  </view>

  <view class="actions">
    <button class="btn-primary" bindtap="createRoom" loading="{{creating}}">
      {{creating ? 'Creating...' : 'Create room'}}
    </button>
    <button class="btn-secondary" bindtap="scanToListen">
      Scan to listen
    </button>
  </view>
</view>
