LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Optional. Local dev defaults to a JSON file under the OS temp directory.
# Production Docker stores this at /app/data/rooms.json on a persistent volume.
GUIDEROOM_ROOM_STORE_PATH=

# Base URL used in QR codes and listener links.
# Local WiFi phone testing: set to your machine's network IP, e.g. http://192.168.1.x:3000
# Production: https://zengsg.dpdns.org
NEXT_PUBLIC_APP_URL=http://localhost:3000
